{
  "@context": {
    "@vocab": "https://schema.org/",
    "healthcare": "https://healthcare.schema.org/",
    "fhir": "http://hl7.org/fhir/"
  },
  "@type": "Patient",
  "@id": "https://healthcare.schema.org/Patient",
  "name": "Patient Schema",
  "description": "JSON-LD schema for patient information in healthcare applications",
  "version": "1.0.0",
  "properties": {
    "@context": {
      "@type": "Text",
      "description": "JSON-LD context"
    },
    "@type": {
      "@type": "Text",
      "description": "Schema type - Patient"
    },
    "@id": {
      "@type": "URL",
      "description": "Unique identifier for the patient"
    },
    "identifier": {
      "@type": "PropertyValue",
      "description": "Medical record number or patient identifier",
      "properties": {
        "name": "Identifier type (e.g., MRN, SSN, Insurance ID)",
        "value": "Identifier value"
      }
    },
    "givenName": {
      "@type": "Text",
      "description": "Patient's first name"
    },
    "familyName": {
      "@type": "Text",
      "description": "Patient's last name"
    },
    "additionalName": {
      "@type": "Text",
      "description": "Patient's middle name"
    },
    "birthDate": {
      "@type": "Date",
      "description": "Patient's date of birth (YYYY-MM-DD)"
    },
    "gender": {
      "@type": "GenderType",
      "description": "Patient's gender (Male, Female, Other, Unknown)"
    },
    "address": {
      "@type": "PostalAddress",
      "description": "Patient's residential address",
      "properties": {
        "streetAddress": "Street address",
        "addressLocality": "City",
        "addressRegion": "State/Province",
        "postalCode": "Postal/ZIP code",
        "addressCountry": "Country"
      }
    },
    "telephone": {
      "@type": "Text",
      "description": "Patient's contact phone number"
    },
    "email": {
      "@type": "Text",
      "description": "Patient's email address"
    },
    "bloodType": {
      "@type": "Text",
      "description": "Patient's blood type (A+, A-, B+, B-, AB+, AB-, O+, O-)"
    },
    "height": {
      "@type": "QuantitativeValue",
      "description": "Patient's height",
      "properties": {
        "value": "Numeric value",
        "unitCode": "Unit (e.g., cm, in)"
      }
    },
    "weight": {
      "@type": "QuantitativeValue",
      "description": "Patient's weight",
      "properties": {
        "value": "Numeric value",
        "unitCode": "Unit (e.g., kg, lb)"
      }
    },
    "medicalCondition": {
      "@type": "MedicalCondition",
      "description": "Array of patient's medical conditions"
    },
    "medication": {
      "@type": "Drug",
      "description": "Array of patient's current medications"
    },
    "allergyIntolerance": {
      "@type": "Text",
      "description": "Array of known allergies and intolerances"
    },
    "emergencyContact": {
      "@type": "Person",
      "description": "Emergency contact information",
      "properties": {
        "name": "Contact name",
        "telephone": "Contact phone",
        "relationship": "Relationship to patient"
      }
    },
    "insuranceProvider": {
      "@type": "Organization",
      "description": "Patient's insurance provider information"
    },
    "primaryCarePhysician": {
      "@type": "Physician",
      "description": "Patient's primary care physician"
    },
    "dateCreated": {
      "@type": "DateTime",
      "description": "Date when patient record was created"
    },
    "dateModified": {
      "@type": "DateTime",
      "description": "Date when patient record was last modified"
    }
  },
  "example": {
    "@context": "https://schema.org/",
    "@type": "Patient",
    "@id": "https://hospital.example.com/patient/12345",
    "identifier": {
      "@type": "PropertyValue",
      "name": "MRN",
      "value": "MRN-12345"
    },
    "givenName": "John",
    "familyName": "Doe",
    "birthDate": "1985-06-15",
    "gender": "Male",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "123 Main Street",
      "addressLocality": "Springfield",
      "addressRegion": "IL",
      "postalCode": "62701",
      "addressCountry": "US"
    },
    "telephone": "+1-555-123-4567",
    "email": "john.doe@example.com",
    "bloodType": "O+",
    "height": {
      "@type": "QuantitativeValue",
      "value": 180,
      "unitCode": "cm"
    },
    "weight": {
      "@type": "QuantitativeValue",
      "value": 75,
      "unitCode": "kg"
    },
    "allergyIntolerance": ["Penicillin", "Peanuts"],
    "emergencyContact": {
      "@type": "Person",
      "name": "Jane Doe",
      "telephone": "+1-555-987-6543",
      "relationship": "Spouse"
    },
    "dateCreated": "2024-01-15T10:30:00Z",
    "dateModified": "2024-03-20T14:45:00Z"
  }
}